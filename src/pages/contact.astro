---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DPVM33GF79" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-DPVM33GF79');
    </script>
    <title>Contact Us | 87 Calculator</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <script is:inline>
        tailwind.config = { darkMode: 'class', theme: { extend: { fontFamily: { sans: ['Outfit', 'sans-serif'] } } } };
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else { document.documentElement.classList.remove('dark'); }
    </script>
</head>
<body class="relative min-h-screen font-sans bg-gradient-to-br from-[#c6a7e0] via-[#f4b7cb] to-[#f9d7b4] dark:from-[#0f0c29] dark:via-[#302b63] dark:to-[#24243e] text-bloomDark dark:text-white p-6 md:p-12 transition-colors duration-500">
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute bottom-0 right-0 w-[80vw] h-[80vw] bg-[#f2a65a] dark:bg-[#e0aaff] rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[120px] opacity-50 dark:opacity-20"></div>
    </div>
    
    <div class="relative z-10 max-w-3xl mx-auto bg-white/40 dark:bg-black/30 backdrop-blur-2xl border border-white/60 dark:border-white/10 rounded-3xl p-8 md:p-12 shadow-xl">
        <a href="/" class="text-sm font-bold opacity-60 hover:opacity-100 transition-opacity">← Back to Calculator Hub</a>
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter mt-6 mb-6">Support Desk.</h1>
        <div class="space-y-4 text-lg font-medium opacity-80 leading-relaxed">
            <p>We are constantly upgrading our algorithms and user interface. If you have a feature request, notice a bug, or have a business/advertising inquiry, we want to hear from you.</p>
            
            <div class="mt-8 bg-white/50 dark:bg-black/40 border border-white/80 dark:border-white/20 p-6 rounded-2xl">
                <span class="block text-xs font-bold uppercase tracking-widest opacity-50 mb-2">Official Contact Registry</span>
                <a href="mailto:87calculators@gmail.com" class="text-2xl md:text-3xl font-extrabold hover:opacity-70 transition-opacity">87calculators@gmail.com</a>
            </div>
        </div>
    </div>
</body>
</html>
